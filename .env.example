# Site (required in production for SEO / absolute URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — required for account deletion (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Server-only — Google Gemini (never expose to the browser)
GEMINI_API_KEY=
# Fast default: gemini-3.1-flash-lite | Higher quality: gemini-3.5-flash
GEMINI_MODEL=gemini-3.1-flash-lite

# RBAC — bootsraps / syncs the owner account (server-only, never expose to browser)
SUPER_ADMIN_EMAIL=admin@mockmate.com
SUPER_ADMIN_PASSWORD=admin123

# Admin email notifications (Resend)
RESEND_API_KEY=re_VGczYLso_HHkcgGCAXPt7nySSWJX8qvLM
ADMIN_NOTIFICATION_EMAIL=ihashimaq@gmail.com
# Optional verified sender; defaults to Resend onboarding address
RESEND_FROM_EMAIL=MockMate <ihashimaq@gmail.com>

# Daily digest cron: Authorization Bearer token for /api/cron/daily-digest
CRON_SECRET=
